modules = ["nodejs-20", "web"]

[nix]
channel = "stable-25_05"

[env]
NODE_ENV = "production"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm dev"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "vm"
run = ["sh", "-c", "pnpm start"]
# Build runs migrations + seed before compiling, so a fresh deploy on a
# new Postgres database boots into a working schema instead of a 500.
# The seed script is idempotent (existing demo tenant is left alone).
build = ["sh", "-c", "pnpm install --frozen-lockfile && pnpm db:migrate && pnpm db:seed && pnpm build"]

[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"
