modules = ["web", "nodejs-20"]

[nix]
channel = "stable-25_05"
packages = ["doppler"]

[env]
NODE_ENV = "production"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm dev"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "vm"
run = ["sh", "-c", "doppler run -- pnpm start"]
# Build runs migrations + seed before compiling, so a fresh deploy on a
# new Postgres database boots into a working schema instead of a 500.
# The seed script is idempotent (existing demo tenant is left alone).
build = ["sh", "-c", "pnpm install --frozen-lockfile && doppler run -- pnpm db:migrate && doppler run -- pnpm db:seed && pnpm build"]

[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"
