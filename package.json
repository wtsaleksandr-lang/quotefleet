{
  "name": "quotefleet",
  "version": "0.1.0",
  "description": "Embeddable instant quote calculator + AI dispatcher for drayage and trucking companies in USA/Canada. Multi-tenant SaaS.",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.1",
  "scripts": {
    "dev": "tsx watch src/server/index.ts",
    "start": "node dist/server/index.js",
    "build": "tsc --project tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed.ts",
    "deploy:replit": "pnpm install && pnpm db:push && pnpm db:seed && pnpm start"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@neondatabase/serverless": "^1.1.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "dayjs": "^1.11.20",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "express": "^5.2.1",
    "nanoid": "^5.0.9",
    "nodemailer": "^6.9.16",
    "postgres": "^3.4.9",
    "tsx": "^4.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^6.4.16",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.7.2"
  }
}
