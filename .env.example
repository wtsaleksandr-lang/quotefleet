# ──────────────────────────────────────────────────────────────────────────
# QuoteFleet — environment configuration
# Copy to .env and fill in the values. On Replit set these as Secrets.
# ──────────────────────────────────────────────────────────────────────────

# REQUIRED — Postgres connection string (Neon recommended, free tier).
# Format: postgresql://user:pass@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/quotefleet?sslmode=require

# REQUIRED — Anthropic API key. Used by the AI agent for rate adjustment,
# auto-reply emails, and customer-service chat. Each tenant can also set
# their own key from the dashboard (overrides this default).
ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional — public base URL of the deployment. Used to generate embed
# snippets that customers paste on their website. Set to your Replit
# deployment URL or custom domain.
PUBLIC_BASE_URL=https://quotefleet.app

# Optional — comma-separated list of platform-owned domains. Each tenant
# gets a subdomain `<slug>.<domain>` on whichever they pick at signup.
# Wildcard DNS for each (`*.<domain>`) must point at this deployment.
# The first entry is the default. See docs/multi-host-setup.md.
HOST_DOMAINS=quotefleet.app,quotefleet.net,truckrate.online,your-quote.online

# Optional — secret used to sign session cookies. If not set, a random
# 32-byte value is generated on first start (bad for prod — set explicitly).
SESSION_SECRET=replace-with-random-32-byte-hex-string

# Optional — port to bind to. Replit's default web port is 5000.
PORT=5000

# Optional — bind host. 0.0.0.0 lets Replit's proxy reach the server.
HOST=0.0.0.0

# Optional — bootstrap super-admin email. The first user that signs up
# with this email is granted super-admin (across-all-tenant) access.
# Useful so you don't have to fiddle with the DB on first deploy.
SUPER_ADMIN_EMAIL=you@yourdomain.com

# Optional — Google Maps API key (Places + Geocoding APIs enabled).
# Drives address autocomplete (USA/Canada only). Reuse a key from another
# project if you have one — restrict it by domain to keep it safe.
GOOGLE_MAPS_API_KEY=

# Optional — Mapbox token, fallback for autocomplete + geocoding.
# Used only if GOOGLE_MAPS_API_KEY is unset.
MAPBOX_TOKEN=

# Optional — SMTP for outgoing email (lead notifications, auto-reply
# to customers, magic-link login). When unset, emails are logged to
# stdout instead of sent (fine for dev / first weeks of pilot).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="QuoteFleet <noreply@quotefleet.com>"

# Optional — EIA (US Energy Info Admin) API key for live diesel-price
# index used in the fuel-surcharge formula. Free key from
# https://www.eia.gov/opendata/. Falls back to a hardcoded recent
# value when unset.
EIA_API_KEY=
